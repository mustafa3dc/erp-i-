#!/bin/bash
# الانتقال إلى مجلد التطبيق تلقائياً
cd "$(dirname "$0")"

echo "=========================================================="
echo "   جاري تشغيل نظام المحاسبة والمخزن (M MOBILE) أوفلاين..."
echo "=========================================================="

# تفعيل البيئة الافتراضية إذا كانت متوفرة
if [ -d "venv" ]; then
    source venv/bin/activate
fi

# تشغيل التطبيق محلياً
python3 run_desktop.py
